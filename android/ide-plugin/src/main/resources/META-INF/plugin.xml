<idea-plugin>
  <id>com.automobile.ide</id>
  <name>AutoMobile</name>
  <vendor email="support@automobile.dev" url="https://github.com/kaeawc/auto-mobile">AutoMobile</vendor>

  <description><![CDATA[
    AutoMobile IDE integration for authoring automated tests and visualizing navigation graphs.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <toolWindow id="AutoMobile" anchor="right" icon="/icons/toolWindow.svg" factoryClass="com.automobile.ide.AutoMobileToolWindowFactory" />
    <applicationConfigurable id="automobile.settings" displayName="AutoMobile" instance="com.automobile.ide.settings.AutoMobileSettingsConfigurable" />
    <applicationConfigurable id="automobile.featureFlags" parentId="automobile.settings" displayName="Feature Flags" instance="com.automobile.ide.settings.FeatureFlagsConfigurable" />
  </extensions>
</idea-plugin>
