---
name: set-alarm-6-30am-demo-mode
description: Set demo mode to 8pm and create 6:30 AM alarm in Clock app
steps:
  - tool: launchApp
    appId: com.google.android.deskclock
    clearAppData: true
    label: Launch Clock application with clean state

  - tool: tapOn
    id: "com.google.android.deskclock:id/tab_menu_alarm"
    label: Tap Alarm tab
    action: "tap"

  - tool: tapOn
    id: "com.google.android.deskclock:id/fab"
    label: Tap add alarm button
    action: "tap"

  - tool: tapOn
    text: "6"
    label: Select 6 for hour
    action: "tap"

  - tool: tapOn
    id: "com.google.android.deskclock:id/material_minute_tv"
    label: Switch to minute selection
    action: "tap"

  - tool: tapOn
    text: "30"
    label: Select 30 for minutes
    action: "tap"

  - tool: tapOn
    text: "OK"
    label: Confirm alarm time selection
    action: "tap"

  - tool: tapOn
    text: "Delete"
    label: Confirm alarm time selection
    action: "tap"

  - tool: terminateApp
    appId: com.google.android.deskclock


