    label: Select 6 for hour
    action: "tap"

  - tool: tapOn
    text: "30"
    label: Select 30 for minutes
    action: "tap"

  - tool: tapOn
    text: "OK"
    label: Confirm alarm time selection
    action: "tap"

  - tool: tapOn
    text: "Delete"
    label: Confirm alarm time selection
    action: "tap"

  - tool: terminateApp
    appId: com.google.android.deskclock


