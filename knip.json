{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "test/**/*.ts",
    "scripts/**/*.ts"
  ],
  "project": [
    "src/**/*.ts",
    "test/**/*.ts",
    "scripts/**/*.ts"
  ],
  "ignore": [
    "dist/**",
    "node_modules/**",
    "android/**",
    "src/db/migrations/**",
    "**/*.d.ts"
  ],
  "ignoreDependencies": ["@types/pixelmatch"],
  "ignoreBinaries": [],
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": true,
  "typescript": {
    "config": "tsconfig.dead-code.json"
  }
}
