{
  "name": "@kaeawc/auto-mobile",
  "version": "0.0.7",
  "description": "Mobile device interaction automation via MCP",
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:memory-leaks": "node --expose-gc --import tsx scripts/detect-memory-leaks.ts",
    "lint": "eslint . --fix",
    "watch": "bun --watch src/index.ts",
    "build": "bun build.ts && chmod +x dist/src/index.js",
    "clean": "rm -rf dist",
    "start": "bun run src/index.ts --transport streamable",
    "dev": "bun --watch src/index.ts --transport streamable",
    "dev:port": "bun --watch src/index.ts --transport streamable --port",
    "dev:stdio": "bun run src/index.ts",
    "dev:sse": "bun --watch src/index.ts --transport sse",
    "dev:streamable": "bun --watch src/index.ts --transport streamable",
    "dev:streamable:port": "bun --watch src/index.ts --transport streamable --port",
    "dev:android": "bash scripts/local-dev/android-hot-reload.sh --skip-ai",
    "dev:android:hot-reload": "bash scripts/local-dev/android-hot-reload.sh",
    "dev:ios": "bash scripts/local-dev/ios-hot-reload.sh --skip-ai",
    "dev:ios:hot-reload": "bash scripts/local-dev/ios-hot-reload.sh",
    "estimate-context": "bun scripts/estimate-context-usage.ts",
    "benchmark-context": "bun scripts/benchmark-context-thresholds.ts",
    "benchmark-tools": "bun scripts/benchmark-mcp-tools.ts",
    "benchmark-startup": "bash scripts/benchmark-startup.sh",
    "benchmark-npm-unpacked-size": "bun scripts/benchmark-npm-unpacked-size.ts",
    "profile:memory": "node --expose-gc --inspect --import tsx scripts/detect-memory-leaks.ts --mode=profile",
    "profile:heap": "node --expose-gc --heap-prof --import tsx scripts/stress-test.ts",
    "validate:yaml": "bun scripts/validate-yaml.ts",
    "dead-code:ts": "bash scripts/detect-dead-code-ts.sh",
    "dead-code:ts:prune": "npx ts-prune",
    "dead-code:ts:knip": "npx knip",
    "prepublishOnly": "cp README.md README.md.backup && bun scripts/npm/transform-readme.js",
    "postpublish": "mv README.md.backup README.md || true"
  },
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": ">=1.3.6"
  },
  "keywords": [
    "adb",
    "android",
    "auto-mobile",
    "automation",
    "bridge",
    "debug",
    "mcp",
    "mobile",
    "ui-testing"
  ],
  "files": [
    "dist",
    "schemas"
  ],
  "main": "dist/src/index.js",
  "bin": {
    "auto-mobile": "dist/src/index.js"
  },
  "author": "Jason Pearson",
  "license": "Apache-2.0",
  "contributors": [
    {
      "name": "Jason Pearson",
      "email": "jason.d.pearson@gmail.com"
    }
  ],
  "homepage": "https://kaeawc.github.io/auto-mobile/",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaeawc/auto-mobile.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.16",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "async-mutex": "^0.5.0",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.0",
    "hono": "4.11.4",
    "jimp": "^1.6.0",
    "js-tiktoken": "^1.0.21",
    "js-yaml": "^4.1.1",
    "kysely": "^0.28.9",
    "onnxruntime-node": "^1.23.2",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "qs": "6.14.1",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "xml2js": "^0.6.2",
    "zod": "^4.3.5"
  },
  "overrides": {
    "lodash": "^4.17.23"
  },
  "//overrides": {
    "lodash": "CVE-2025-13465: prototype pollution in _.unset and _.omit"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.38.0",
    "@faker-js/faker": "^10.2.0",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@types/express": "^5.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.0.9",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/proxyquire": "^1.3.31",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@typescript-eslint/utils": "^8.53.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.38.0",
    "eslint-plugin": "^1.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-notice": "^1.0.0",
    "heapdump": "^0.3.15",
    "knip": "^5.81.0",
    "memwatch-next": "^0.3.0",
    "proxyquire": "^2.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
